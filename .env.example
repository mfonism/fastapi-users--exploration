# Environment selection: local | test | staging | production
APP_ENV=local

# Enable/disable FastAPI debug mode.
# If omitted, defaults to true for local/test and false for staging/production.
DEBUG=true

# Database (async SQLAlchemy URL is built from these parts)
DB_DRIVER=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_BASE_NAME=explore
AUTH_REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX_BASE=explore_auth_tokens

# Security secrets (replace in real environments)
RESET_PASSWORD_TOKEN_SECRET=change-me-reset-secret
VERIFICATION_TOKEN_SECRET=change-me-verification-secret
